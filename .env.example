DATABASE_URL=postgresql://user:password@localhost:5432/gruene_aktionen
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://aktionen.gruene-mitte.de
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=aktionen@gruene-mitte.de
EMAIL_FROM_NAME=Kreisvorstand B90/GRÜNE Berlin-Mitte
CRON_SECRET=your-cron-secret-here
# Cron-Jobs (täglich einrichten):
# Tagesübersicht (z.B. 21 Uhr):
#   0 21 * * * curl -s -X POST -H "Authorization: Bearer $CRON_SECRET" http://127.0.0.1:3000/api/cron/daily-summary
# Anmeldedaten-Löschung nach 72h (stündlich):
#   0 * * * * curl -s -X POST -H "Authorization: Bearer $CRON_SECRET" http://127.0.0.1:3000/api/cron/cleanup-anmeldungen
